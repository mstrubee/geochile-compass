# Lovable Cloud / app environment

# Manzanas API — leave empty to use the bundled MockManzanaService.
# Point to a PostGIS-backed REST endpoint to switch to real INE Censo 2017 data.
VITE_MANZANA_API_URL=

# Future migration to Google Maps tiles
VITE_GOOGLE_MAPS_KEY=

# Overpass API (OSM) — override only if you run your own instance
VITE_OVERPASS_URL=https://overpass-api.de/api/interpreter
